# Environment variables for SDR CRM
# Copy this to .env.local and fill in the values

# Neon Database
VITE_NEON_AUTH_URL=https://your-project.neonauth.sa-east-1.aws.neon.tech/neondb/auth
VITE_NEON_DATA_API_URL=https://your-project.apirest.sa-east-1.aws.neon.tech/neondb/rest/v1

# OpenRouter (get your key at https://openrouter.ai/keys)
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here